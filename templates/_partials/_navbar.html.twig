<header class="fixed top-0 left-0 right-0 z-[9999] w-full border-b border-base-content/10 bg-base-100/95 backdrop-blur-lg shadow-sm">
  <nav class="mx-auto flex max-w-[1280px] items-center justify-between px-4 sm:px-6 lg:px-8" style="height: 76px;">

    {# ── Logo ── #}
    <a class="flex items-center gap-3 group shrink-0" href="{{ path('app_home') }}">
      <img src="{{ asset('images/logowithnobackground.png') }}"
           alt="EduPulse"
           style="height: 52px; width: 52px; object-fit: contain; display: block;"
      />
      <div class="flex flex-col leading-none">
        <span class="text-base-content text-lg font-bold tracking-tight">EduPulse</span>
        <span class="text-[9px] font-bold uppercase tracking-widest text-primary" style="margin-top: 2px;">by O.Bouchahwa</span>
      </div>
    </a>

    {# ── Desktop Nav Links (hidden on mobile) ── #}
    <div class="hidden lg:flex items-center" style="gap: 2rem;">
      <a href="#home"       class="text-sm font-semibold text-base-content/70 hover:text-primary transition-colors whitespace-nowrap">Accueil</a>
      <a href="#features"   class="text-sm font-semibold text-base-content/70 hover:text-primary transition-colors whitespace-nowrap">Fonctionnalités</a>
      <a href="#formations" class="text-sm font-semibold text-base-content/70 hover:text-primary transition-colors whitespace-nowrap">Formations</a>
      <a href="#team"       class="text-sm font-semibold text-base-content/70 hover:text-primary transition-colors whitespace-nowrap">Équipe</a>
      <a href="#faqs"       class="text-sm font-semibold text-base-content/70 hover:text-primary transition-colors whitespace-nowrap">FAQ</a>
    </div>

    {# ── Desktop CTA (hidden on mobile) ── #}
    <div class="hidden lg:flex items-center shrink-0" style="gap: 1rem;">
      <a href="#" class="text-sm font-semibold text-base-content/70 hover:text-primary transition-colors">Connexion</a>
      <a href="#contact" class="btn btn-primary btn-sm rounded-full px-6 text-sm">Commencer</a>
    </div>

    {# ── Mobile Burger Button (visible on mobile only) ── #}
    <div class="flex items-center gap-2 lg:hidden">
      <a href="#contact" class="btn btn-primary btn-xs rounded-full px-4 text-xs">Commencer</a>
      <button id="mobile-menu-btn"
              type="button"
              class="btn btn-ghost btn-square btn-sm"
              aria-label="Toggle navigation"
              onclick="
                var panel = document.getElementById('mobile-menu-panel');
                var icon1 = document.getElementById('burger-icon');
                var icon2 = document.getElementById('close-icon');
                if (panel.style.display === 'block') {
                  panel.style.display = 'none';
                  icon1.style.display = 'block';
                  icon2.style.display = 'none';
                } else {
                  panel.style.display = 'block';
                  icon1.style.display = 'none';
                  icon2.style.display = 'block';
                }
              ">
        <svg id="burger-icon" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" style="width:20px;height:20px;display:block;">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" />
        </svg>
        <svg id="close-icon" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" style="width:20px;height:20px;display:none;">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </div>
  </nav>

  {# ── Mobile Menu Panel ── #}
  <div id="mobile-menu-panel"
       style="display: none;"
       class="lg:hidden border-t border-base-content/10 bg-base-100 shadow-lg">
    <div class="flex flex-col px-4 py-3" style="gap: 0.25rem;">
      <a href="#home"       onclick="document.getElementById('mobile-menu-panel').style.display='none'; document.getElementById('burger-icon').style.display='block'; document.getElementById('close-icon').style.display='none';"
         class="rounded-lg px-3 py-3 text-sm font-semibold text-base-content/70 hover:bg-base-200 hover:text-primary transition-colors">Accueil</a>
      <a href="#features"   onclick="document.getElementById('mobile-menu-panel').style.display='none'; document.getElementById('burger-icon').style.display='block'; document.getElementById('close-icon').style.display='none';"
         class="rounded-lg px-3 py-3 text-sm font-semibold text-base-content/70 hover:bg-base-200 hover:text-primary transition-colors">Fonctionnalités</a>
      <a href="#formations" onclick="document.getElementById('mobile-menu-panel').style.display='none'; document.getElementById('burger-icon').style.display='block'; document.getElementById('close-icon').style.display='none';"
         class="rounded-lg px-3 py-3 text-sm font-semibold text-base-content/70 hover:bg-base-200 hover:text-primary transition-colors">Formations</a>
      <a href="#team"       onclick="document.getElementById('mobile-menu-panel').style.display='none'; document.getElementById('burger-icon').style.display='block'; document.getElementById('close-icon').style.display='none';"
         class="rounded-lg px-3 py-3 text-sm font-semibold text-base-content/70 hover:bg-base-200 hover:text-primary transition-colors">Équipe</a>
      <a href="#faqs"       onclick="document.getElementById('mobile-menu-panel').style.display='none'; document.getElementById('burger-icon').style.display='block'; document.getElementById('close-icon').style.display='none';"
         class="rounded-lg px-3 py-3 text-sm font-semibold text-base-content/70 hover:bg-base-200 hover:text-primary transition-colors">FAQ</a>
      <div class="border-t border-base-content/10 mt-2 pt-2">
        <a href="#" class="rounded-lg px-3 py-3 text-sm font-semibold text-base-content/70 hover:bg-base-200 hover:text-primary transition-colors block">Connexion</a>
      </div>
    </div>
  </div>
</header>